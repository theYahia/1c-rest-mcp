{
  "name": "@theyahia/1c-rest-mcp",
  "version": "1.2.1",
  "description": "MCP server for 1C Enterprise — ERP catalogs, documents via REST API (Russia)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "1c-rest-mcp": "dist/index.js",
    "1c-rest-mcp-http": "dist/http.js"
  },
  "files": [
    "dist",
    "smithery.yaml"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/http.ts",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.theYahia/1c-rest-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai",
    "russian-api",
    "1c",
    "1c-enterprise",
    "erp",
    "documents",
    "catalogs",
    "registers",
    "reports",
    "odata",
    "1c-rest",
    "api",
    "typescript",
    "accounting",
    "fastmcp",
    "ai-tools",
    "ai-agents",
    "developer-tools",
    "llm",
    "agentic-framework",
    "automation",
    "workflow",
    "self-hosted"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theYahia/1c-rest-mcp.git"
  },
  "homepage": "https://github.com/theYahia/1c-rest-mcp#readme",
  "author": "theYahia (https://github.com/theYahia)"
}
